generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Amenity {
  id           Int           @id
  name         String
  reservations Reservation[]
}

model Reservation {
  id        Int     @id
  amenityId Int
  userId    Int
  startTime Int
  endTime   Int
  date      DateTime

  amenity Amenity @relation(fields: [amenityId], references: [id])

  @@index([amenityId, date])
  @@index([userId, date])
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
